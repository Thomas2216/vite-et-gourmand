{% extends 'base.html.twig' %}

{% block title %}Les Menus{% endblock %}

{% block body %}

    <div class="menus-hero">
        <h1 class="menus-hero-title">Nos Menus</h1>
        <p class="menus-hero-text">
            Chez Vite &amp; Gourmand, nous avons imaginé des menus qui allient rapidité et plaisir.
            Que vous soyez pressé le midi ou simplement en quête d'un repas savoureux, nos formules
            sont pensées pour satisfaire toutes les envies.<br>
            Des ingrédients soigneusement sélectionnés, des recettes gourmandes et des portions
            généreuses : chaque menu est conçu pour vous offrir un moment de dégustation simple,
            efficace et délicieux.
        </p>
    </div>

    <div class="menus-grid-wrapper">
        {% if menus|length %}
            <div class="menus-grid">
                {% for menu in menus %}
                    <div class="menu-card">

                        {% if menu.titre == 'Menu Italien' %}
                            <img src="{{ asset('images/menu_italien.png') }}" class="menu-card-img" alt="Menu Italien">
                        {% elseif menu.titre == 'Menu Healthy' %}
                            <img src="{{ asset('images/menu_healthy.png') }}" class="menu-card-img" alt="Menu Healthy">
                        {% elseif menu.titre == 'Menu Gourmet' %}
                            <img src="{{ asset('images/menu_gourmet.png') }}" class="menu-card-img" alt="Menu Gourmet">
                        {% elseif menu.titre == 'Menu Famille' %}
                            <img src="{{ asset('images/menu_famille.png') }}" class="menu-card-img" alt="Menu Famille">
                        {% elseif menu.titre == 'Menu Express' %}
                            <img src="{{ asset('images/menu_express.png') }}" class="menu-card-img" alt="Menu Express">
                        {% endif %}

                        <div class="menu-card-body">
                            <h3 class="menu-card-title">{{ menu.titre }}</h3>
                            <p class="menu-card-desc">{{ menu.description|raw }}</p>

                            <div class="menu-card-meta">
                                <span class="menu-card-meta-item">👥 {{ menu.minPersonne }} pers. min.</span>
                                <span class="menu-card-meta-item menu-card-price">{{ menu.prixFormate }} € / pers.</span>
                            </div>

                            {% if menu.regime %}
                                <span class="menu-card-regime">{{ menu.regime }}</span>
                            {% endif %}
                        </div>

                        <div class="menu-card-footer">
                            <a href="{{ path('app_menu_detail', {'id': menu.id}) }}" class="menu-card-btn">
                                Voir le détail
                            </a>
                        </div>

                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="menus-empty">Aucun menu disponible pour le moment.</p>
        {% endif %}
    </div>

{% endblock %}
