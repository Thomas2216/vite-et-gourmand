{% extends 'base.html.twig' %}

{% block title %}{{ menu.titre }}{% endblock %}

{% block body %}

    <div class="detail-hero">
        <div class="detail-hero-content">
            <h1 class="detail-hero-title">{{ menu.titre }}</h1>
            <p class="detail-hero-desc">{{ menu.description|raw }}</p>

            <div class="detail-meta">
                <div class="detail-meta-tile">
                    <span class="detail-meta-label">Prix</span>
                    <span class="detail-meta-value">{{ menu.prixFormate }} € / pers.</span>
                </div>
                <div class="detail-meta-tile">
                    <span class="detail-meta-label">Personnes min.</span>
                    <span class="detail-meta-value">{{ menu.minPersonne }}</span>
                </div>
                <div class="detail-meta-tile">
                    <span class="detail-meta-label">Thème</span>
                    <span class="detail-meta-value">{{ menu.theme }}</span>
                </div>
                {% if menu.regime %}
                    <div class="detail-meta-tile">
                        <span class="detail-meta-label">Régime</span>
                        <span class="detail-meta-value">{{ menu.regime }}</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="detail-plats-section">

        <h2 class="detail-plats-title">Composition du menu</h2>

        {% if menu.plats|length > 0 %}
            <div class="plats-grid">
                {% for plat in menu.plats %}
                    <div class="plat-card">
                        <span class="plat-card-type">{{ plat.type }}</span>
                        <h3 class="plat-card-nom">{{ plat.nom }}</h3>
                        {% if plat.allergene %}
                            <span class="badge-allergene">⚠ {{ plat.allergene }}</span>
                        {% else %}
                            <span class="badge-allergene badge-allergene--none">Aucun allergène</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="detail-plats-empty">Aucun plat associé à ce menu.</p>
        {% endif %}

        <div class="detail-actions">
            <a href="{{ path('app_commande', {'menuId': menu.id}) }}" class="btn-commander">
                Commander ce menu
            </a>
            <a href="{{ path('app_menus') }}" class="btn-retour">
                ← Retour aux menus
            </a>
        </div>

    </div>

{% endblock %}
