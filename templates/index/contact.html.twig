{% extends 'base.html.twig' %}

{% block title %}Contact - Vite & Gourmand{% endblock %}

{% block body %}

    <div class="container-contact">

        <h1>Contactez-nous</h1>

        <p class="text-contact">
            Vous avez une question, une suggestion ou simplement envie de nous dire bonjour ?<br>
            N'hésitez pas à remplir le formulaire ci-dessous.
        </p>

        {{ form_start(form, {'attr': {'class': 'creation-form'}}) }}

            {{ form_errors(form) }}

            {{ form_row(form.titre) }}
            {{ form_row(form.email) }}
            {{ form_row(form.description) }}

            {{ form_row(form.submit) }}

        {{ form_end(form) }}

        <div class="contact-info">
            <h2>Informations complémentaires</h2>
            <ul class="contact-info-list">
                <li>
                    <span class="contact-info-label">Email</span>
                    <a href="mailto:contact@viteetgourmand.fr">contact@viteetgourmand.fr</a>
                </li>
                <li>
                    <span class="contact-info-label">Téléphone</span>
                    01 23 45 67 89
                </li>
            </ul>
        </div>

    </div>

{% endblock %}
