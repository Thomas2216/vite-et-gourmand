<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{% endblock %}</title>

        {% block stylesheets %}
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header>
            <nav class="navbar navbar-expand-lg bg-body-tertiary">
                <div class="container-fluid">
                    <img class="logo" src="{{ asset('images/logo_2.png') }}" alt="Logo Vite & Gourmand" width="200" height="200">

                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarSupportedContent"
                            aria-controls="navbarSupportedContent"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_accueil') }}">Accueil</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_menus') }}">Menus</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="{{ path ('app_contact') }}">Contact</a>
                            </li>
                            {% if app.user is null %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                                </li>
                            {% elseif is_granted('ROLE_ADMIN') or is_granted('ROLE_EMPLOYE') %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('admin') }}">Espace Administrateur</a>
                                </li>
                            {% else %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_user') }}">Votre Espace</a>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success m-3">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger m-3">
                {{ message }}
            </div>
        {% endfor %}

        {% block body %}
        {% endblock %}

            <footer class="footer">
                <div>
                    <img src="{{ asset('images/facebook-icon.png') }}" width="24" alt="logo fbk">
                    <a href="https://www.facebook.com/" class="text-footer">Facebook</a>
                </div>

                <div>
                    <img src="{{ asset('images/instagram-icon.png') }}" width="24" alt="logo insta">
                    <a href="https://www.instagram.com/" class="text-footer">Instagram</a>
                </div>

                <div>
                    <a href="mailto:contact@viteetgourmand.fr" class="text-footer">Mail</a>
                </div>

                <div>
                    <a href="{{ path('app_mentions') }}" class="text-footer">Mentions légales</a>
                </div>

                <p>&copy; 2026 Vite & Gourmand. Tous droits réservés.</p>
            </footer>
    </body>
</html>
